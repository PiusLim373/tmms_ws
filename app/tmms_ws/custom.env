echo "Setup unitree ros2 communications environment with custom built cyclonedds"
source /opt/ros/jazzy/setup.bash
source /home/htxgrrt/.htxgrrt/bin/tmms_ws/install/setup.bash
export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
export CYCLONEDDS_URI="/home/htxgrrt/.htxgrrt/bin/tmms_ws/cyclonedds.xml"

print_gradient_banner() {
    local banner_lines=(
        "▐▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▌"
        "▐                                                        ▌"
        "▐ ██╗  ██╗████████╗██╗  ██╗                              ▌"
        "▐ ██║  ██║╚══██╔══╝╚██╗██╔╝                              ▌"
        "▐ ███████║   ██║    ╚███╔╝                               ▌"
        "▐ ██╔══██║   ██║    ██╔██╗                               ▌"
        "▐ ██║  ██║   ██║   ██╔╝ ██╗                              ▌"
        "▐ ╚═╝  ╚═╝   ╚═╝   ╚═╝  ╚═╝                              ▌"
        "▐ ██████╗  █████╗ ██╗   ██╗███████╗     ██████╗ ███████╗ ▌"
        "▐ ██╔══██╗██╔══██╗██║   ██║██╔════╝    ██╔════╝ ██╔════╝ ▌"
        "▐ ██████╔╝███████║██║   ██║███████╗    ██║  ███╗███████╗ ▌"
        "▐ ██╔══██╗██╔══██║██║   ██║╚════██║    ██║   ██║╚════██║ ▌"
        "▐ ██║  ██║██║  ██║╚██████╔╝███████║    ╚██████╔╝███████║ ▌"
        "▐ ╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝ ╚══════╝     ╚═════╝ ╚══════╝ ▌"
        "▐                                                        ▌"
        "▐▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▌"
    )

    # Gradient endpoints (for the interior text): #5c068d (top-left) -> #00ccff (bottom-right)
    local r1=92 g1=6 b1=141
    local r2=0 g2=204 b2=255
    # Frame (outer border) color: solid white
    local frame_r=255 frame_g=255 frame_b=255

    local rows=${#banner_lines[@]}
    local cols=${#banner_lines[0]}
    local row col line char t r g b out segment is_frame

    echo
    for ((row = 0; row < rows; row++)); do
        line=${banner_lines[row]}
        out=""
        for ((col = 0; col < cols; col++)); do
            char=${line:col:1}
            is_frame=0
            (( row == 0 || row == rows - 1 || col == 0 || col == cols - 1 )) && is_frame=1
            if (( is_frame )); then
                r=$frame_r; g=$frame_g; b=$frame_b
            else
                t=$((( row * 1000 / (rows - 1) + col * 1000 / (cols - 1) ) / 2))
                t=$(( t * t / 1000 ))
                r=$(( r1 + (r2 - r1) * t / 1000 ))
                g=$(( g1 + (g2 - g1) * t / 1000 ))
                b=$(( b1 + (b2 - b1) * t / 1000 ))
            fi
            printf -v segment '\e[38;2;%d;%d;%dm%s' "$r" "$g" "$b" "$char"
            out+=$segment
        done
        printf '%s\e[0m\n' "$out"
    done
    echo
}

print_gradient_banner