source /home/htxgrrt/.htxgrrt/bin/tmms_ws/install/setup.bash
export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
export CYCLONEDDS_URI="/home/htxgrrt/.htxgrrt/bin/tmms_ws/install/share/tmms_ws/cyclonedds.xml"

